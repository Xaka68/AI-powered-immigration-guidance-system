# ── Backend (read by backend/src/core/config.py) ─────────────────────────────
# Copy to .env and fill in. The LLM endpoint is OpenAI-compatible, so the same
# vars work for OpenAI, a self-hosted vLLM/Ollama server, etc. (swappable).
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# Multilingual embedding model so a non-German query matches German pages.
EMBED_MODEL=intfloat/multilingual-e5-large

# Integreat source region (no city hardcoded in code).
INTEGREAT_REGION=testumgebung-frag-integreat

# ── Frontend (read by Next.js; must be prefixed NEXT_PUBLIC_) ─────────────────
# Point the frontend at the backend. Put this in frontend/.env.local.
NEXT_PUBLIC_API_URL=http://localhost:8000
