# Frontend config (Vite).
#
# Standalone / preview (no backend): leave both unset, or set VITE_USE_MOCK=true.
#   The app uses the built-in mock in src/lib/mock.ts.
#
# Real backend (local demo): point at the FastAPI server and disable the mock.
#   VITE_API_URL=http://localhost:8000

# VITE_API_URL=http://localhost:8000
# VITE_USE_MOCK=true
