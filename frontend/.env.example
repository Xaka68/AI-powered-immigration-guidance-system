# Frontend config (Vite). Copy to .env.local for a machine-local override.
#
# Standalone / preview (default if unset): uses the built-in mock (src/lib/mock.ts).
#   VITE_USE_MOCK=true
#
# Live backend (D8): point at the FastAPI server and disable the mock.
VITE_API_URL=http://localhost:8000
VITE_USE_MOCK=false
